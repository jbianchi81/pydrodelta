{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "uhlinearchannelprocedurefunction.json",
    "title": "UHLinearChannelProcedureFunction",
    "type": "object",
    "description": "Unit Hydrograph linear channel procedure function",
    "allOf": [
        {
            "$ref": "procedurefunction.json"
        }
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "UHLinearChannel"
            ]
        },
        "parameters": {
            "type": "object",
            "description": "Model parameters",
            "properties": {
                "u": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "number"
                    },
                    "description": "distribution function that represent the apportionment of the unit pulse. Array of numbers"
                }
            },
            "required": ["u"],
            "additionalProperties": false
        },
        "extra_pars": {
            "type": "object",
            "description": "Additional, non-calibratable parameters",
            "properties": {
                "dt": {
                    "type": "number",
                    "description": "calculation timestep (1 = the timestep of the input series). Default: 1"
                }       
            }
        },
        "boundaries": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["input"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        },
        "outputs": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["output"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        }
    },
    "required": [
        "type",
        "parameters"
    ]
}