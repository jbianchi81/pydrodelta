{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "linearnetprocedurefunction.json",
    "title": "LinearNetProcedureFunction",
    "type": "object",
    "description": "Nash linear net procedure function for 2 or more inputs and 1 output",
    "allOf": [
        {
            "$ref": "procedurefunction.json"
        }
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "LinearNet"
            ]
        },
        "parameters": {
            "type": "object",
            "desciption": "Model parameters",
            "properties": {
                "k_1": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_1": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_2": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_2": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_3": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_3": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_4": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_4": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_5": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_5": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_6": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_6": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_7": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_7": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_8": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_8": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_9": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_9": {
                    "type": "number",
                    "description": "number of reservoirs"
                },
                "k_10": {
                    "type": "number",
                    "description": "residence time"
                },
                "n_10": {
                    "type": "number",
                    "description": "number of reservoirs"
                }
            },
            "required": ["k_1","n_1","k_2","n_2"],
            "additionalProperties": false
        },
        "extra_pars": {
            "type": "object",
            "properties": {
                "dt": {
                    "type": "number",
                    "description": "calculation timestep (1 = the timestep of the input series). Default: 1"
                }
            }
        },
        "boundaries": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["input_1","input_2","input_3","input_4","input_5","input_6","input_7","input_8","input_9","input_10"]
                            }
                        }
                    }
                ]
            },
            "minItems": 2,
            "maxItems": 10,
            "uniqueItems": true
        },
        "outputs": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["output"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        }
    },
    "required": [
        "type",
        "parameters"
    ]
}