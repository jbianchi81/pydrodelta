{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "linearfitprocedurefunction.json",
    "title": "LinearFitProcedureFunction",
    "type": "object",
    "description": "Procedure function that fits a linear function between an independent variable (input) and a response and then applies the resulting function to the input values to produce the output",
    "allOf": [
        {
            "$ref": "genericfitprocedurefunction.json"
        }
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "LinearFit"
            ]
        },
        "boundaries": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["input"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        },
        "outputs": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["output"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        }
   },
    "required": [
        "type"
    ]
}