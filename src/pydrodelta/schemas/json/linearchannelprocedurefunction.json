{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "linearchannelprocedurefunction.json",
    "title": "LinearChannelProcedureFunction",
    "type": "object",
    "description": "Nash linear channel procedure function",
    "allOf": [
        {
            "$ref": "procedurefunction.json"
        }
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "LinearChannel"
            ]
        },
        "parameters": {
            "type": "object",
            "desciption": "Model parameters",
            "properties": {
                "k": {
                    "type": "number",
                    "description": "residence time"
                },
                "n": {
                    "type": "number",
                    "description": "number of reservoirs"
                }
            },
            "required": ["k","n"]
        },
        "extra_pars": {
            "type": "object",
            "properties": {
                "dt": {
                    "type": "number",
                    "description": "calculation timestep (1 = the timestep of the input series). Default: 1"
                }
            }
        },
        "boundaries": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["input"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        },
        "outputs": {
            "type": "array",
            "items": {
                "allOf": [
                    { "$ref": "procedureboundary.json"},
                    {
                        "type": "object",
                        "properties": {
                            "name": {
                                "enum": ["output"]
                            }
                        }
                    }
                ]
            },
            "minItems": 1,
            "maxItems": 1
        }
    },
    "required": [
        "type",
        "parameters"
    ]
}