{
    "$id": "plan.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Plan",
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "id": {
        "type": "integer",
        "description": "Identificador de 'calibrado' en la API de destino (output_api) donde se almacenarán las 'corridas'"
      },
      "topology": {
        "description": "Either topology object or topology file path",
        "oneOf": [
          {
            "$ref": "topology.json"
          },
          {
            "type": "string"
          }
        ]
      },
      "procedures": {
        "type": "array",
        "description": "Ordered list of procedures (of class Procedure). On .execute(), they are executed sequentially. The results are read and saved into the topology according to the mapping configuration in procedure.boundaries and procedure.outputs respectively, so that the procedures read the updated data generated by previous procedures",
        "items": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string"
            }
          },
          "discriminator": {
            "propertyName": "type"
          },
          "oneOf": [
            {
              "properties": {
                "type": {
                  "enum": ["Abstract", "AbstractProcedure"]
                }
              },
              "$ref": "abstractprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["HecRas", "HecRasProcedure"]
                }
              },
              "$ref": "hecrasprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["Polynomial", "PolynomialProcedure"]
                }
              },
              "$ref": "polynomialtransformationprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": [
                      "LinearCombination",
                      "LinearCombination2B",
                      "LinearCombination3B",
                      "LinearCombination4B",
                      "LinearCombinationProcedure",
                      "LinearCombination2BProcedure",
                      "LinearCombination3BProcedure",
                      "LinearCombination4BProcedure"
                  ]
                }
              },
              "$ref": "linearcombinationprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["Expression", "ExpressionProcedure"]
                }
              },
              "$ref": "expressionprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["SacramentoSimplified", "SacramentoSimplifiedProcedure"]
                }
              },
              "$ref": "sacramentosimplifiedprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["SacramentoSimplifiedFixedPars", "SacramentoSimplifiedFixedParsProcedure"]
                }
              },
              "$ref": "sacramentosimplifiedfixedparsprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["GRP", "GRPProcedure"]
                }
              },
              "$ref": "grpprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["GR4J_", "GR4J_Procedure"]
                }
              },
              "$ref": "gr4j_procedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["GR4J", "GR4JProcedure"]
                }
              },
              "$ref": "gr4jprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["SacEnKF", "SacEnKFProcedure", "SacEnkfProcedure"]
                }
              },
              "$ref": "sacenkfprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": [
                      "Junction",
                      "JunctionProcedure",
                      "Difference",
                      "DifferenceProcedure"
                  ]
                }
              },
              "$ref": "junctionprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LinearChannel", "LinearChannelProcedure"]
                }
              },
              "$ref": "linearchannelprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["UHLinearChannel", "UHLinearChannelProcedure"]
                }
              },
              "$ref": "uhlinearchannelprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["MuskingumChannel", "MuskingumChannelProcedure"]
                }
              },
              "$ref": "muskingumchannelprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["HOSH4P1L", "HOSH4P1LProcedure", "HOSH4P1LNash", "HOSH4P1LNashProcedure"]
                }
              },
              "$ref": "hosh4p1lprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LinearNet", "LinearNetProcedure"]
                }
              },
              "$ref": "linearnetprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LinearNet3", "LinearNet3Procedure"]
                }
              },
              "$ref": "linearnet3procedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["ExponentialFit", "ExponentialFitProcedure"]
                }
              },
              "$ref": "exponentialfitprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LinearFit", "LinearFitProcedure"]
                }
              },
              "$ref": "linearfitprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LagAndRoute", "LagAndRouteProcedure"]
                }
              },
              "$ref": "lagandrouteprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["LagAndRouteNet", "LagAndRouteNetProcedure"]
                }
              },
              "$ref": "lagandroutenetprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["HIDROSAT", "HIDROSATProcedure"]
                }
              },
              "$ref": "hidrosatprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["Analogy", "AnalogyProcedure"]
                }
              },
              "$ref": "analogyprocedure.json"
            },
            {
              "properties": {
                "type": {
                  "enum": ["Persistence", "PersistenceProcedure"]
                }
              },
              "$ref": "persistenceprocedure.json"
            }
          ]
        }
      },
      "forecast_date": {
        "$ref": "dateorinterval.json",
        "description": "Execution timestamp of the plan. Defaults to now rounded down to .time_interval"
      },
      "time_interval": {
        "$ref": "timeinterval.json",
        "description": "time step duration of the procedures"
      },
      "output_stats": {
        "type": "string",
        "description": "statistics output file"
      },
      "output_results": {
        "type": "string",
        "description": "results output file"
      },
      "output_analysis": {
        "type": "string",
        "description": "analysis output file"
      },
      "pivot": {
        "type": "boolean",
        "description": "Option to pivot the results table (set one column per variable). Default False"
      },
      "save_post": {
        "type": "string",
        "description": "Local path where to save simulation post data (json)"
      },
      "save_response": {
        "type": "string",
        "description": "Local path where to save simulation post response (json)"
      },
      "output_sim_csv": {
        "type": "string",
        "description": "Save simulation series as csv"
      },
      "save_variable_sim": {
        "type": "array",
        "description": "Save simulation series as csv, each variable into a different file",
        "items": {
          "type": "object",
          "properties": {
            "var_id": {
              "type": "number",
              "description": "Variable id"
            },
            "output": {
              "type": "string",
              "description": "output filename"
            }
          }
        }
      },
      "qualifiers": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Include this forecast members into the simulation output"
      },
      "output_graph": {
        "type": "string",
        "description": "File path where to save graph representation of the plan"
      }
    },
    "required": [
      "id",
      "name",
      "topology",
      "procedures"
    ],
    "additionalProperties": false
}